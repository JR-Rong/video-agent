# ===== LLM Providers (sensitive) =====
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ===== OpenAI (fallback image only) =====
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=gpt-image-1

# ===== Kling (video; and future image if you provide doc) =====
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_BASE_URL=https://api-beijing.klingai.com

# ===== Paths =====
DATA_DIR=./data
OUTPUT_DIR=./data/outputs
EXPORT_DIR=./data/export
MEDIA_LIBRARY_DIR=./data/media_library

# ===== Config paths =====
PROVIDERS_CONFIG=./configs/providers.yaml
CATEGORIES_CONFIG=./configs/categories.yaml
OUTPUT_ROUTING_CONFIG=./configs/output_routing.yaml
RENDER_PRESETS_CONFIG=./configs/render_presets.yaml
PROMPTS_DIR=./prompts

# ===== Render =====
FFMPEG_BIN=ffmpeg
RENDER_PRESET=vertical_1080x1920

# ===== TTS =====
TTS_PROVIDER=edge_tts
TTS_VOICE=zh-CN-XiaoxiaoNeural

# ===== Safety =====
STRICT_SAFETY=true

